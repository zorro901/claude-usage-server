# Docker / sender
CLAUDE_USAGE_INGEST_URL=https://<your-worker>.workers.dev
CLAUDE_USAGE_INGEST_TOKEN=<shared-secret>
CLAUDE_USAGE_HOST_LABEL=macbook-pro-1
CLAUDE_USAGE_USER_LABEL=taro
CLAUDE_USAGE_INTERVAL_SECONDS=300
CLAUDE_USAGE_STATE_DIR=/Users/user/.claude-usage-state

# Optional fallback for older scripts
CLAUDE_USAGE_WEBHOOK_URL=

# Cloudflare deploy helper
CLOUDFLARE_INGEST_TOKEN=<shared-secret>
CLOUDFLARE_DASHBOARD_PASSWORD=<dashboard-secret>
CLOUDFLARE_WRANGLER_BIN=npx wrangler
